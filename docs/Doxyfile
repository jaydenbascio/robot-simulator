# Doxygen Configuration File for Robot Simulator

# Project metadata
PROJECT_NAME           = "Robot Simulator"
PROJECT_NUMBER         = "1.0.0"
OUTPUT_DIRECTORY       = docs

# Language and formatting
OUTPUT_LANGUAGE        = English
TAB_SIZE               = 4
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES

# Extraction settings
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_PRIV_VIRTUAL   = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_LOCAL_METHODS  = YES
EXTRACT_ANON_NSPACES   = YES

# Warning configuration, crucial for CI validation
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_AS_ERRORS         = YES

# Input configuration
INPUT                  = libs apps README.md STYLE_GUIDE.md
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.h *.hpp *.cpp
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */tests/* */build/* */vcpkg_installed/*

# Output formats
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_XML           = NO

# Configure Doxygen input and output folders
INPUT                  = ../libs ../apps
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.hpp
OUTPUT_DIRECTORY       = . 
