<?xml version="1.0" encoding="utf-8"?>
<!--
  Chocolatey package manifest for this project's developer toolchain.
  Installed by scripts\setup.ps1 via:  choco install packages.config -y

  Keep this list intentionally minimal and opinionated:
    - vscode.install: the ONLY supported editor for this project
    - llvm          : clang, clang-format, lld and friends (compiler toolchain)
    - cmake.install : build-file generation
    - ninja         : build backend
    - git.install   : version control (redundant with the bootstrap, kept for completeness)
    - msys2         : provides the base pacman environment used to install the
                       MinGW-w64 GCC toolchain (setupc.ps1 runs a follow-up
                       pacman step after this - see Install-MinGWToolchain).
                       Needed so vcpkg can build the x64-mingw-static triplet.

  NOTE: use the ".install" package id, not the bare metapackage ("git",
  "vscode", "cmake"), for git/vscode/cmake. The bare id is just a metapackage
  with no installer of its own - it depends on the ".install" package, which
  is where the actual installer/uninstaller and any installArguments live.
  This matters for BOTH directions:
    - install: installArguments (e.g. cmake's ADD_CMAKE_TO_PATH) only apply
      to the package you name, and never reach the metapackage's dependency.
    - uninstall: "choco uninstall git" looks for a package literally named
      "git" in Chocolatey's local registry. If only "git.install" was ever
      registered (the normal case), that lookup finds nothing, silently
      no-ops, and the real program is never removed.
-->
<packages>
  <package id="git.install" />
  <package id="vscode.install" />
  <package id="llvm" />
  <package id="cmake.install" installArguments="ADD_CMAKE_TO_PATH=System" />
  <package id="ninja" />
  <package id="msys2" />
</packages>
