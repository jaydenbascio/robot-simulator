<?xml version="1.0" encoding="utf-8"?>
<!--
  Chocolatey manifest for this project's developer toolchain. Installed natively by
  setupc.ps1 via a single "choco install <this file>" call (choco treats any *.config
  path as a manifest and honors each package's installArguments). See AGENTS.md.

  Use the ".install" package id (git.install / vscode.install / cmake.install), NOT
  the bare metapackage: installArguments only apply to the exact package named, and
  "choco uninstall <id>" looks up that literal id - a bare-metapackage-only install
  leaves nothing for uninstall to find.

    vscode.install : the supported editor for this project
    llvm           : clang, clang-format, lld (compiler toolchain)
    cmake.install  : build-file generation (ADD_CMAKE_TO_PATH so cmake lands on PATH)
    ninja          : build backend
    git.install    : version control (redundant with the bootstrap; kept for completeness)
    mingw          : MinGW-w64 GCC toolchain (gcc on PATH), so vcpkg's x64-mingw-static
                     / x64-mingw-dynamic triplets have a compiler. Replaces the former
                     msys2 + pacman bootstrap - this choco package installs the compiler
                     directly and adds it to PATH, with no follow-up step needed.
-->
<packages>
  <package id="git.install" />
  <package id="vscode.install" />
  <package id="llvm" />
  <package id="cmake.install" installArguments="ADD_CMAKE_TO_PATH=System" />
  <package id="ninja" />
  <package id="mingw" />
</packages>
